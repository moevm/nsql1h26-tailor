    "@vicons/utils": "^0.1.4",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.9.1",
    "naive-ui": "^2.43.2",
    "sass-embedded": "^1.97.3",
    "vfonts": "^0.0.3",
    "vite": "^8.0.9",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.7"
