{
  "name": "@nosql/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "UNLICENSED",
  "description": "Frontend for the tailor app project.",
  "contributors": [
    "Korshkov Aleksandr",
    "Pivoev Nikita",
    "Otmakhov Danil"
  ],
  "scripts": {
    "generate:api": "orval --config orval.config.ts",
    "lint": "eslint src --cache",
    "format": "prettier --write src --cache",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "format:check": "prettier --check src --cache",
    "pre-commit": "pnpm generate:api && pnpm typecheck && pnpm lint && pnpm format",
    "dev": "concurrently -n orval,frontend -c blue,magenta \"pnpm generate:api --watch\" \"vite\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "axios": "^1.15.0",
    "chart.js": "^4.5.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vicons/material": "^0.13.0",
    "@vicons/utils": "^0.1.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "naive-ui": "^2.44.1",
    "orval": "^8.7.0",
    "sass-embedded": "^1.99.0",
    "vfonts": "^0.0.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  }
}
